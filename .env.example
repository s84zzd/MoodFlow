# DeepSeek API 配置
# 请复制此文件为 .env 并填入你的 API Key
# ⚠️ 重要：不要将真实的 API Key 提交到代码仓库！
# 在 Vercel 部署时，请在项目设置中添加环境变量

VITE_DEEPSEEK_API_KEY=your-api-key-here
VITE_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
VITE_DEEPSEEK_MODEL=deepseek-chat

# 可选：启用/禁用 AI 功能
VITE_ENABLE_AI=false

# 打卡限制配置
# true = 启用每日8次打卡限制（生产环境建议启用）
# false = 取消打卡限制（本地开发使用）
VITE_ENABLE_CHECKIN_LIMIT=true

# AI建议限制配置
# true = 启用每日8次AI建议限制（生产环境建议启用）
# false = 取消AI建议限制，无限使用（本地开发使用）
VITE_ENABLE_AI_ADVICE_LIMIT=true
